{
  "name": "@grmkris/bull-viewer-api",
  "version": "0.1.0",
  "description": "oRPC routers, scope middleware, and typed errors for bull-viewer",
  "license": "MIT",
  "author": "Kristjan Grm",
  "homepage": "https://github.com/grmkris/bull-viewer",
  "repository": {
    "type": "git",
    "url": "https://github.com/grmkris/bull-viewer.git",
    "directory": "packages/api"
  },
  "type": "module",
  "files": [
    "src",
    "package.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "ultracite check",
    "fix": "ultracite fix",
    "fix:unsafe": "ultracite fix --unsafe"
  },
  "dependencies": {
    "@grmkris/bull-viewer-core": "workspace:*",
    "@orpc/openapi": "^1.13.4",
    "@orpc/server": "^1.13.4",
    "@orpc/zod": "^1.13.4",
    "bullmq": "^5.73.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@grmkris/bull-viewer-test-utils": "workspace:*",
    "@types/bun": "^1.3.12",
    "typescript": "^5.9.3"
  }
}
