{
  "name": "@bull-viewer/standalone",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "bull-viewer": "./src/index.ts"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsgo --noEmit",
    "lint": "ultracite check",
    "fix": "ultracite fix",
    "fix:unsafe": "ultracite fix --unsafe"
  },
  "dependencies": {
    "@bull-viewer/api": "workspace:*",
    "@bull-viewer/core": "workspace:*",
    "@bull-viewer/ui": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.9.3"
  }
}
