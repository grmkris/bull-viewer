{
  "name": "@grmkris/bull-viewer-standalone",
  "version": "0.1.0",
  "description": "Hono server fronting BullMQ for the bull-viewer dashboard",
  "license": "MIT",
  "author": "Kristjan Grm",
  "homepage": "https://github.com/grmkris/bull-viewer",
  "repository": {
    "type": "git",
    "url": "https://github.com/grmkris/bull-viewer.git",
    "directory": "packages/standalone"
  },
  "bin": {
    "bull-viewer": "./src/index.ts"
  },
  "type": "module",
  "files": [
    "src",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "ultracite check",
    "fix": "ultracite fix",
    "fix:unsafe": "ultracite fix --unsafe"
  },
  "dependencies": {
    "@grmkris/bull-viewer-api": "workspace:*",
    "@grmkris/bull-viewer-core": "workspace:*",
    "@grmkris/bull-viewer-ui": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.9.3"
  }
}
