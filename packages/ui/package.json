{
  "name": "@grmkris/bull-viewer-ui",
  "version": "0.1.0",
  "description": "React UI for bull-viewer (embed library bundle + standalone SPA)",
  "license": "MIT",
  "author": "Kristjan Grm",
  "homepage": "https://github.com/grmkris/bull-viewer",
  "repository": {
    "type": "git",
    "url": "https://github.com/grmkris/bull-viewer.git",
    "directory": "packages/ui"
  },
  "files": [
    "dist",
    "src/embed.tsx"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/embed.tsx",
      "import": "./dist/lib/index.js"
    },
    "./styles.css": "./dist/lib/ui.css",
    "./standalone": "./dist/standalone/"
  },
  "scripts": {
    "dev": "vite dev --port 5173",
    "build": "bun run build:lib && bun run build:standalone && bun run bundle-guard",
    "build:standalone": "VITE_BUILD_MODE=standalone vite build --outDir dist/standalone",
    "build:lib": "VITE_BUILD_MODE=lib vite build --outDir dist/lib",
    "bundle-guard": "bun run scripts/bundle-guard.ts",
    "typecheck": "tsgo --noEmit",
    "lint": "ultracite check",
    "fix": "ultracite fix",
    "fix:unsafe": "ultracite fix --unsafe"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@grmkris/bull-viewer-api": "workspace:*",
    "@grmkris/bull-viewer-core": "workspace:*",
    "@orpc/client": "^1.13.4",
    "@orpc/tanstack-query": "^1.13.4",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@uiw/react-codemirror": "^4.25.9",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "uplot": "^1.6.32",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
