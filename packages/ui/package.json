{
  "name": "@bull-viewer/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/embed.tsx",
      "import": "./dist/lib/index.js"
    },
    "./styles.css": "./dist/lib/ui.css",
    "./standalone": "./dist/standalone/"
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite dev --port 5173",
    "build": "bun run build:lib && bun run build:standalone",
    "build:standalone": "VITE_BUILD_MODE=standalone vite build --outDir dist/standalone",
    "build:lib": "VITE_BUILD_MODE=lib vite build --outDir dist/lib",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,css}\""
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@bull-viewer/api": "workspace:*",
    "@bull-viewer/core": "workspace:*",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-router": "^1.167.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
