{
  "name": "@grmkris/bull-viewer-next",
  "version": "0.1.0",
  "description": "Next.js page + route handlers for embedding bull-viewer",
  "license": "MIT",
  "author": "Kristjan Grm",
  "homepage": "https://github.com/grmkris/bull-viewer",
  "repository": {
    "type": "git",
    "url": "https://github.com/grmkris/bull-viewer.git",
    "directory": "packages/next"
  },
  "type": "module",
  "files": [
    "src",
    "package.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "lint": "ultracite check",
    "fix": "ultracite fix",
    "fix:unsafe": "ultracite fix --unsafe"
  },
  "dependencies": {
    "@grmkris/bull-viewer-api": "workspace:*",
    "@grmkris/bull-viewer-core": "workspace:*",
    "@grmkris/bull-viewer-ui": "workspace:*",
    "bullmq": "^5.73.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "next": "^15.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  }
}
