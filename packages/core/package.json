{
  "name": "@grmkris/bull-viewer-core",
  "version": "0.1.0",
  "description": "BullMQ adapter, registry, and snapshot helpers for bull-viewer",
  "license": "MIT",
  "author": "Kristjan Grm",
  "homepage": "https://github.com/grmkris/bull-viewer",
  "repository": {
    "type": "git",
    "url": "https://github.com/grmkris/bull-viewer.git",
    "directory": "packages/core"
  },
  "type": "module",
  "files": [
    "src",
    "package.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "lint": "ultracite check",
    "fix": "ultracite fix",
    "fix:unsafe": "ultracite fix --unsafe"
  },
  "dependencies": {
    "bullmq": "^5.73.4",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
